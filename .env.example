# PostgreSQL
POSTGRES_USER=text2sql
POSTGRES_PASSWORD=text2sql_dev
POSTGRES_DB=text2sql
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# App
APP_ENV=development
LOG_LEVEL=INFO

# Inference mode: "mock" for Phase 1, "local" for OmniSQL-7B, "sagemaker" for AWS
INFERENCE_MODE=mock

# OmniSQL model path (used when INFERENCE_MODE=local)
# MODEL_PATH=seeklhy/OmniSQL-7B

# AWS (used when INFERENCE_MODE=sagemaker) - fill in Phase 3
# AWS_REGION=us-east-1
# SAGEMAKER_ENDPOINT_NAME=omnisql-pg-endpoint